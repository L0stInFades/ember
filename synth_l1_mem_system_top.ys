# Synthesize the split L1 subsystem through a small-IO wrapper for nextpnr.
read_verilog cache.v
read_verilog cache_client_arbiter2.v
read_verilog mem_arbiter2.v
read_verilog slowmem.v
read_verilog l1_mem_system.v
read_verilog syn_top_l1_mem_system.v
hierarchy -top syn_top_l1_mem_system
synth_ecp5 -top syn_top_l1_mem_system -json syn_top_l1_mem_system.json
stat
